<Window x:Class="SchemaSentinel.UI.Windows.ExportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview"
        Width="900" Height="650" MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="ContentBox"
                 Grid.Row="0"
                 IsReadOnly="True"
                 FontFamily="Consolas" FontSize="11"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"
                 Margin="10,10,10,0"
                 BorderBrush="#CCC" BorderThickness="1"
                 Background="White" Padding="6"/>

        <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="10,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CopyAllButton"
                        Content="Copy All"
                        Width="88" Height="28" Margin="0,0,8,0"
                        Background="#1A3A5C" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontSize="12"
                        Click="CopyAll_Click"/>
                <Button x:Name="SaveAsButton"
                        Content="Save As..."
                        Width="88" Height="28" Margin="0,0,8,0"
                        Background="#27AE60" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontSize="12"
                        Click="SaveAs_Click"/>
                <Button x:Name="CloseButton"
                        Content="Close"
                        Width="70" Height="28"
                        Background="#888" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontSize="12"
                        IsCancel="True"
                        Click="Close_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
