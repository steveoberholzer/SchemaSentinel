<UserControl x:Class="SchemaSentinel.UI.Controls.ConnectionPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:SchemaSentinel.UI.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:ConnectionStatusToColorConverter x:Key="ConnStatusColor"/>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
        </Style>
    </UserControl.Resources>

    <GroupBox Padding="8">
        <GroupBox.Header>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="13"/>
                <Ellipse Width="10" Height="10" Margin="8,0,0,0"
                         Fill="{Binding IsConnected, Converter={StaticResource ConnStatusColor}}"/>
            </StackPanel>
        </GroupBox.Header>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Server -->
            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Server"/>
            <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource FieldBox}"
                     Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,0"
                     ToolTip="On-prem: MyServer\Instance&#x0a;Azure SQL DB: myserver.database.windows.net&#x0a;Azure SQL MI (public endpoint): myinstance.public.&lt;dns-zone&gt;.database.windows.net,3342"/>
            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="10" Foreground="#999"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,0,2"
                       Text="Azure MI: add .public. and ,3342"
                       ToolTip="Azure SQL Managed Instance public endpoint format:&#x0a;myinstance.public.&lt;dns-zone&gt;.database.windows.net,3342&#x0a;&#x0a;Windows auth only works inside the VNet.&#x0a;Use SQL Server auth for public endpoint access."/>

            <!-- Database -->
            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Database"/>
            <TextBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource FieldBox}"
                     Text="{Binding DatabaseName, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Auth type -->
            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Authentication"/>
            <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,2,0,4">
                <RadioButton Content="Windows" IsChecked="{Binding IsWindowsAuth}" Margin="0,0,12,0" FontSize="12"/>
                <RadioButton Content="SQL Server" IsChecked="{Binding IsSqlAuthentication}" Margin="0,0,12,0" FontSize="12"/>
                <RadioButton Content="Entra MFA" IsChecked="{Binding IsEntraMfaAuthentication}" FontSize="12"
                             ToolTip="Microsoft Entra Interactive (MFA). Opens a browser for sign-in — no password needed here."/>
            </StackPanel>

            <!-- Username field (SQL Auth + Entra MFA) -->
            <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                        Visibility="{Binding ShowUsernameField, Converter={StaticResource BoolToVis}}">
                <TextBlock Style="{StaticResource FieldLabel}">
                    <Run Text="Username"/>
                    <Run Text=" (login hint)" Foreground="#999"
                         FontSize="10">
                        <Run.Style>
                            <Style TargetType="Run">
                                <Setter Property="Foreground" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEntraMfa}" Value="True">
                                        <Setter Property="Foreground" Value="#999"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Run.Style>
                    </Run>
                </TextBlock>
                <TextBox Style="{StaticResource FieldBox}" Margin="0,0,0,4"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <!-- Password field (SQL Auth only) -->
            <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                        Visibility="{Binding ShowPasswordField, Converter={StaticResource BoolToVis}}">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Password"/>
                <PasswordBox x:Name="PasswordBox" Padding="4,3" FontSize="12" BorderBrush="#CCC" Margin="0,0,0,4"
                             PasswordChanged="PasswordBox_PasswordChanged"/>
            </StackPanel>

            <!-- Entra MFA note -->
            <Border Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,2,0,4"
                    Background="#EBF5FB" BorderBrush="#AED6F1" BorderThickness="1" CornerRadius="3" Padding="8,5"
                    Visibility="{Binding IsEntraMfa, Converter={StaticResource BoolToVis}}">
                <TextBlock FontSize="11" Foreground="#1A5276" TextWrapping="Wrap"
                           Text="A browser window will open when you click Test Connection or Compare. Sign in with MFA and return here once complete."/>
            </Border>

            <!-- Tenant ID field (Entra MFA only) -->
            <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                        Visibility="{Binding ShowTenantField, Converter={StaticResource BoolToVis}}">
                <TextBlock Style="{StaticResource FieldLabel}">
                    <Run Text="Tenant ID"/>
                    <Run Text=" (optional)" Foreground="#999" FontSize="10"/>
                </TextBlock>
                <TextBox Style="{StaticResource FieldBox}" Margin="0,0,0,4"
                         Text="{Binding TenantId, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Your Azure AD tenant ID (GUID). Find it in Azure Portal → Azure Active Directory → Overview.&#x0a;Required if your login account is a guest in the tenant that owns this SQL server."/>
            </StackPanel>

            <!-- Options row -->
            <StackPanel Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,4,0,2">
                <CheckBox Content="Encrypt" IsChecked="{Binding Encrypt}" FontSize="11" Margin="0,0,10,0"/>
                <CheckBox Content="Trust Server Certificate" IsChecked="{Binding TrustServerCertificate}" FontSize="11"/>
            </StackPanel>

            <!-- Test Connection button + status -->
            <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="Test Connection"
                        Command="{Binding TestConnectionCommand}"
                        Padding="10,4" FontSize="12"
                        Background="#1A3A5C" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
                <TextBox Text="{Binding ConnectionStatus, Mode=OneWay}"
                         FontSize="11" Margin="10,0,0,0"
                         Foreground="{Binding IsConnected, Converter={StaticResource ConnStatusColor}}"
                         TextWrapping="Wrap" MaxWidth="220"
                         IsReadOnly="True" BorderThickness="0" Background="Transparent"
                         VerticalScrollBarVisibility="Auto" MaxHeight="80"/>
            </StackPanel>
        </Grid>
    </GroupBox>
</UserControl>
